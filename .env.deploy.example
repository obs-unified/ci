# Shared Cloudflare credentials used by ci/scripts/*.sh.
#
# Copy this file to .env.deploy (gitignored) and fill in the token:
#   cp ci/.env.deploy.example ci/.env.deploy
#
# Then verify the token works:
#   ci/scripts/check-env.sh

# -----------------------------------------------------------------------------
# Cloudflare API token
# -----------------------------------------------------------------------------
# Create at: https://dash.cloudflare.com/profile/api-tokens
#
# Use the "Edit zone DNS" template, then add the Pages permission:
#   • Account permissions:
#       - Cloudflare Pages           : Edit
#   • Zone permissions (scoped to obsunified.com):
#       - DNS                        : Edit
#       - Zone                       : Read
#
# This token is enough for:
#   - ci/scripts/attach-dns.sh        — create/update CNAMEs
#   - wrangler pages deploy           — script-driven deploys
#   - REST API for Pages custom domains, deployments, project metadata
#
CLOUDFLARE_API_TOKEN=

# -----------------------------------------------------------------------------
# Account and zone IDs (kept here so scripts don't have to hardcode them)
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=61d3245b7e3224d49a9553bdb4d1a70e
CLOUDFLARE_ZONE_ID=d427d43500d56be3381a62c1f13c8089
